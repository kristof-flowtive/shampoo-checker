<SCRIPT language="JavaScript">
      function submitWait() {
        setTimeout('submitForm()',<esi:vars>$int($(refresh_seconds))*1000</esi:vars>); //convert to milliseconds
        return(true);
      }
      function submitForm() {
        document.waitroomform.submit();
      }
    </SCRIPT>
  </esi:otherwise>
</esi:choose>
<esi:comment text=" ---------------------- END PROTOCOL-SPECIFIC BODY ----------------------- "/>

<esi:comment text=" --------------- CUSTOMIZE BODY ------------ "/>
<esi:comment text=" --------- Content below is shown for both GET and POST requests --------- "/>
<main>
